<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Global Widget Settings"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Preview"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_preview"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:cardBackgroundColor="#F5F5F5"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#DDDDDD"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#40000000"
                android:layout_marginHorizontal="24dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Widget Preview"
                android:gravity="center"
                android:textColor="#888888" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Widget Corner Radius"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/txt_radius_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="16dp"
            android:textStyle="bold" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seek_radius"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="32"
        android:progress="16"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This setting affects all widgets on your home screen. Note: On older Android versions, changes might require a manual refresh."
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray" />

</LinearLayout>
