<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingVertical="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configure Widget"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:textAlignment="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Data URL"
            android:textStyle="bold"
            android:textSize="14sp" />
        <EditText
            android:id="@+id/edit_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://example.com/data.json"
            android:inputType="textUri"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Background Color (HEX)"
            android:textStyle="bold"
            android:textSize="14sp" />
        <EditText
            android:id="@+id/edit_bg_color"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="#FFFFFF"
            android:text="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Transparency (0.0 to 1.0)"
            android:textStyle="bold"
            android:textSize="14sp" />
        <EditText
            android:id="@+id/edit_bg_alpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="1.0"
            android:text="1.0"
            android:inputType="numberDecimal"
            android:layout_marginBottom="16dp" />

        <CheckBox
            android:id="@+id/check_screen_on"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Update only when screen is on"
            android:checked="true"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Progress Bar Visibility"
            android:textStyle="bold"
            android:textSize="14sp" />
        <RadioGroup
            android:id="@+id/radio_progress_vis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">
            <RadioButton
                android:id="@+id/radio_always"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Always Show"
                android:checked="true" />
            <RadioButton
                android:id="@+id/radio_on_tap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show only on Tap" />
        </RadioGroup>

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save and Update Widget"
            android:padding="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
